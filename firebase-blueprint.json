{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A bus ticket booking",
      "type": "object",
      "properties": {
        "userUid": { "type": "string" },
        "origin": { "type": "string" },
        "destination": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "amount": { "type": "number" },
        "passengers": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userUid", "origin", "destination", "date", "time", "status", "amount", "passengers", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Ticket bookings"
    }
  }
}
